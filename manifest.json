{
  "manifest_version": 3,
  "name": "Jira Quick Copy",
  "version": "1.1.0",
  "description": "Copy Jira issue or Bitbucket PR title as a formatted link with one click.",
  "permissions": ["clipboardWrite", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.atlassian.net/*", "*://*.bitbucket.org/*", "*://*.github.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
